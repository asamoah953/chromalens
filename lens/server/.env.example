# ─── Server Environment Variables ───────────────────────────────
# Copy this file to .env and fill in your values

# Port to run the server on
PORT=5000

# MongoDB Atlas connection string
CONECTION_STRING=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>

# JWT signing secret — use a long random string in production
SECRET_KEY=your-very-long-random-secret-key-here

# Public URL of THIS server (used to build uploaded image URLs)
# e.g. on Render: https://chromalens-api.onrender.com
APP_URL=https://your-backend-url.com

# URL of the frontend (used for CORS allow-origin)
# e.g. https://chromalens.vercel.app
CLIENT_URL=https://your-frontend-url.com
